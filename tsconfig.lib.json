{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "noEmit": false,
    "outDir": "lib",
    "rootDir": "src",
    "tsBuildInfoFile": "lib/.tsconfig.lib.tsbuildinfo",
    "types": []
  },
  "include": [
    "src/index.ts",
    "src/graph/**/*.ts",
    "src/jsonld/**/*.ts",
    "src/renderer/**/*.ts",
    "src/renderer/**/*.tsx"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ]
}
