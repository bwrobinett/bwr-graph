{
  "name": "bwr-graph",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && npm run build:lib && vite build",
    "build:lib": "tsc -p tsconfig.lib.json",
    "prepare": "npm run build:lib",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "chat": "vite-node src/demo/chatbot/cli.ts",
    "story": "vite-node src/demo/story/cli.ts"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.2.7",
    "@types/jsonld": "^1.5.15",
    "jsonld": "^9.0.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-redux": ">=9"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^25.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-redux": "^9.3.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.6",
    "vitest": "^2.1.1"
  }
}
